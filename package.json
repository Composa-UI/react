{
  "name": "@composa-ui/react",
  "version": "0.1.0",
  "type": "module",
  "description": "Composa UI — a React component library and Storybook harness modeled on Figma's UI3 interface patterns.",
  "license": "MIT",
  "author": "Samuel Alake",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Composa-UI/react.git"
  },
  "homepage": "https://github.com/Composa-UI/react#readme",
  "bugs": {
    "url": "https://github.com/Composa-UI/react/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "ui",
    "figma",
    "ui3",
    "storybook",
    "design-tokens"
  ],
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "src/react/index.js",
    "src/react/index.d.ts",
    "src/react/factory.js",
    "src/react/factory.d.ts",
    "src/react/builtin-glyphs.js",
    "styles.css",
    "design/tokens.css",
    "design/generated/composa-core-tokens.css",
    "design/generated/composa-semantic-tokens.css",
    "THIRD-PARTY-NOTICES.md",
    "LICENSE-APACHE-2.0.txt"
  ],
  "types": "./src/react/index.d.ts",
  "scripts": {
    "build:tokens": "node style-dictionary.config.js",
    "build:css": "node tools/build-styles.mjs",
    "check:tokens": "node tools/verify-token-parity.mjs",
    "check": "npm run build:tokens && npm run build:css && node tools/verify-token-parity.mjs && node tools/verify-design-system-contracts.js && node tools/verify-react-entrypoint.js && npm run check:syntax",
    "check:syntax": "find src .storybook -name '*.js' -exec node --check {} \\; && node --check tools/verify-design-system-contracts.js && node --check tools/verify-react-entrypoint.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run check && npm test",
    "storybook": "HOME=.cache/storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev --port ${PORT:-6011} --no-open",
    "build-storybook": "HOME=.cache/storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "serve-storybook": "python3 -m http.server ${PORT:-6010} --directory storybook-static"
  },
  "exports": {
    ".": {
      "types": "./src/react/index.d.ts",
      "default": "./src/react/index.js"
    },
    "./factory": {
      "types": "./src/react/factory.d.ts",
      "default": "./src/react/factory.js"
    },
    "./tokens.css": "./design/tokens.css",
    "./styles.css": "./styles.css"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/react-vite": "^10.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.5",
    "style-dictionary": "^5.4.4",
    "vite": "^8.0.16",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
