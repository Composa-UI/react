{
  "figma": {
    "composa": {
      "radius": {
        "none": { "$type": "dimension", "$value": "0" },
        "small": { "$type": "dimension", "$value": "2px" },
        "medium": { "$type": "dimension", "$value": "5px" },
        "large": { "$type": "dimension", "$value": "13px" },
        "full": { "$type": "dimension", "$value": "9999px" }
      },
      "space": {
        "0": { "$type": "dimension", "$value": "0" },
        "1": { "$type": "dimension", "$value": "4px" },
        "2": { "$type": "dimension", "$value": "8px" },
        "2-5": { "$type": "dimension", "$value": "12px", "$description": "Composa extension — UI3 Sizing has no 12px spacer (UI3 spacers are 0/4/8/16/24/32/40). Kept for existing Composa layouts." },
        "3": { "$type": "dimension", "$value": "16px", "$description": "Maps to UI3 spacer-3 (16)." },
        "4": { "$type": "dimension", "$value": "24px", "$description": "UI3 spacer-4." },
        "5": { "$type": "dimension", "$value": "32px", "$description": "UI3 spacer-5." },
        "6": { "$type": "dimension", "$value": "40px", "$description": "UI3 spacer-6." }
      },
      "height": {
        "input": { "$type": "dimension", "$value": "24px" },
        "heading": { "$type": "dimension", "$value": "40px" }
      }
    }
  }
}
