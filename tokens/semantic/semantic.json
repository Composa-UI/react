      "bg-brand-secondary": { "$type": "color", "$value": "{figma.composa.color.bg-brand-secondary}", "$extensions": { "composa": { "aliasKey": "color.bg.brandSecondary" } } },
      "bg-brand-tertiary": { "$type": "color", "$value": "{figma.composa.color.bg-brand-tertiary}", "$extensions": { "composa": { "aliasKey": "color.bg.brandTertiary" } } },
      "border-brand": { "$type": "color", "$value": "{figma.composa.color.border-brand}", "$extensions": { "composa": { "aliasKey": "color.border.brand" } } },
      "border-strong": { "$type": "color", "$value": "{figma.composa.color.border-strong}", "$extensions": { "composa": { "aliasKey": "color.border.strong" } } },
      "special-shadow": { "$type": "color", "$value": "{figma.composa.color.special-shadow}", "$extensions": { "composa": { "aliasKey": "color.special.shadow" } } },
      "bg-disabled": { "$type": "color", "$value": "{figma.composa.color.bg-disabled}", "$extensions": { "composa": { "aliasKey": "color.bg.disabled" } } },
      "text-disabled": { "$type": "color", "$value": "{figma.composa.color.text-disabled}", "$extensions": { "composa": { "aliasKey": "color.text.disabled" } } },
      "border-disabled": { "$type": "color", "$value": "{figma.composa.color.border-disabled}", "$extensions": { "composa": { "aliasKey": "color.border.disabled" } } },
      "bg-brand-pressed": { "$type": "color", "$value": "{figma.composa.color.brand-pressed}", "$extensions": { "composa": { "$description": "Composa brand primary pressed/hover (darkened Composa orange). Pairs with the deliberate color.bg-brand re-map.", "aliasKey": "color.bg.brandPressed" } } },
      "bg-pressed": { "$type": "color", "$value": "{figma.composa.color.bg-pressed}", "$extensions": { "composa": { "aliasKey": "color.bg.pressed" } } },
      "text-brand": { "$type": "color", "$value": "{figma.composa.color.text-brand}", "$extensions": { "composa": { "aliasKey": "color.text.brand" } } },
      "icon-on-brand": { "$type": "color", "$value": "{figma.composa.color.icon-on-brand}", "$extensions": { "composa": { "aliasKey": "color.icon.onBrand" } } },
      "bg-inverse": { "$type": "color", "$value": "{figma.composa.color.bg-inverse}", "$extensions": { "composa": { "aliasKey": "color.bg.inverse" } } },
      "text": { "$type": "color", "$value": "{figma.composa.color.text}", "$extensions": { "composa": { "aliasKey": "color.text" } } },
      "text-secondary": { "$type": "color", "$value": "{figma.composa.color.text-secondary}", "$extensions": { "composa": { "aliasKey": "color.text.secondary" } } },
      "text-tertiary": { "$type": "color", "$value": "{figma.composa.color.text-tertiary}", "$extensions": { "composa": { "aliasKey": "color.text.tertiary" } } },
      "text-on-brand": { "$type": "color", "$value": "{figma.composa.color.text-on-brand}", "$extensions": { "composa": { "aliasKey": "color.text.onBrand" } } },
      "text-on-inverse": { "$type": "color", "$value": "{figma.composa.color.text-on-inverse}", "$extensions": { "composa": { "aliasKey": "color.text.onInverse" } } },
      "icon": { "$type": "color", "$value": "{figma.composa.color.icon}", "$extensions": { "composa": { "aliasKey": "color.icon" } } },
      "icon-secondary": { "$type": "color", "$value": "{figma.composa.color.icon-secondary}", "$extensions": { "composa": { "aliasKey": "color.icon.secondary" } } },
      "icon-tertiary": { "$type": "color", "$value": "{figma.composa.color.icon-tertiary}", "$extensions": { "composa": { "aliasKey": "color.icon.tertiary" } } },
      "scrollbar": { "$type": "color", "$value": "{figma.composa.color.scrollbar}", "$extensions": { "composa": { "aliasKey": "color.scrollbar" } } },
      "multiplayer-yellow": { "$type": "color", "$value": "{figma.composa.color.multiplayer-yellow}", "$extensions": { "composa": { "aliasKey": "color.multiplayer.yellow" } } },
      "text-on-multiplayer-yellow": { "$type": "color", "$value": "{figma.composa.color.text-on-multiplayer-yellow}", "$extensions": { "composa": { "aliasKey": "color.text.onMultiplayerYellow" } } }
