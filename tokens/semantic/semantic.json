{
  "composa": {
    "$description": "SEMANTIC layer — code-facing --composa-* aliases that reference primitives. Components consume ONLY these names. Hand-authored component-level tokens (control/menu/switch/tooltip/dialog/tabs/Composa and computed values such as radius-large and text-secondary-observed) are NOT pure primitive references and live in the hand-authored overrides layer design/tokens.css. The $extensions.composa.aliasKey on each token preserves the canonical dotted key used in the design/generated/composa-core-tokens.json aliases mirror.",
    "color": {
      "bg": { "$type": "color", "$value": "{figma.composa.color.bg}", "$extensions": { "composa": { "aliasKey": "color.bg" } } },
      "bg-secondary": { "$type": "color", "$value": "{figma.composa.color.bg-secondary}", "$extensions": { "composa": { "aliasKey": "color.bg.secondary" } } },
      "bg-secondary-on-canvas": { "$type": "color", "$value": "{figma.composa.color.bg-secondary-on-canvas}", "$extensions": { "composa": { "aliasKey": "color.bg.secondaryOnCanvas" } } },
      "bg-brand": { "$type": "color", "$value": "{figma.composa.color.brand-default}", "$extensions": { "composa": { "$description": "Composa product brand primary. DELIBERATELY diverges from UI3's bg-brand (#0d99ff) — references the formal composa.color.brand-default primitive (#ff5c16, Composa orange).", "aliasKey": "color.bg.brand", "aliasKeyAlso": { "color.bg.brandCanonical": "{figma.composa.color.bg-brand}" } } } },
      "bg-on-selected": { "$type": "color", "$value": "{figma.composa.color.bg-on-selected}", "$extensions": { "composa": { "aliasKey": "color.bg.onSelected" } } },
      "bg-selected": { "$type": "color", "$value": "{figma.composa.color.bg-selected}", "$extensions": { "composa": { "aliasKey": "color.bg.selected" } } },
      "bg-selected-secondary": { "$type": "color", "$value": "{figma.composa.color.bg-selected-secondary}", "$extensions": { "composa": { "aliasKey": "color.bg.selectedSecondary" } } },
      "bg-tertiary": { "$type": "color", "$value": "{figma.composa.color.bg-tertiary}", "$extensions": { "composa": { "aliasKey": "color.bg.tertiary" } } },
      "accent": { "$type": "color", "$value": "{figma.composa.color.accent}", "$extensions": { "composa": { "$description": "Selection-control accent (blue). Distinct from color.bg-brand (orange). Themeable brand≠accent delineation.", "aliasKey": "color.accent" } } },
      "bg-hover-transparent": { "$type": "color", "$value": "{figma.composa.color.bg-hover-transparent}", "$extensions": { "composa": { "aliasKey": "color.bg.hoverTransparent" } } },
      "bg-transparent-secondary-hover": { "$type": "color", "$value": "{figma.composa.color.bg-transparent-secondary-hover}", "$extensions": { "composa": { "aliasKey": "color.bg.transparentSecondaryHover" } } },
      "accent-blue": { "$type": "color", "$value": "{figma.composa.color.accent-blue}", "$extensions": { "composa": { "aliasKey": "color.accent.blue" } } },
      "accent-component": { "$type": "color", "$value": "{figma.composa.color.accent-component}", "$extensions": { "composa": { "aliasKey": "color.accent.component" } } },
      "accent-measure": { "$type": "color", "$value": "{figma.composa.color.accent-measure}", "$extensions": { "composa": { "aliasKey": "color.accent.measure" } } },
      "accent-spacing": { "$type": "color", "$value": "{figma.composa.color.accent-spacing}", "$extensions": { "composa": { "aliasKey": "color.accent.spacing" } } },
      "text-component": { "$type": "color", "$value": "{figma.composa.color.text-component}", "$extensions": { "composa": { "aliasKey": "color.text.component" } } },
      "fs-canvas-default-fill": { "$type": "color", "$value": "{figma.composa.color.fs-canvas-default-fill}", "$extensions": { "composa": { "aliasKey": "color.fsCanvasDefaultFill" } } },
      "border": { "$type": "color", "$value": "{figma.composa.color.border}", "$extensions": { "composa": { "aliasKey": "color.border" } } },
      "border-translucent": { "$type": "color", "$value": "{figma.composa.color.border-translucent}", "$extensions": { "composa": { "aliasKey": "color.borderTranslucent" } } },
      "border-selected": { "$type": "color", "$value": "{figma.composa.color.border-selected}", "$extensions": { "composa": { "aliasKey": "color.border.selected" } } },
      "bg-danger": { "$type": "color", "$value": "{figma.composa.color.bg-danger}", "$extensions": { "composa": { "aliasKey": "color.bg.danger" } } },
      "text-danger": { "$type": "color", "$value": "{figma.composa.color.text-danger}", "$extensions": { "composa": { "aliasKey": "color.text.danger" } } },
      "icon-danger": { "$type": "color", "$value": "{figma.composa.color.icon-danger}", "$extensions": { "composa": { "aliasKey": "color.icon.danger" } } },
      "border-danger": { "$type": "color", "$value": "{figma.composa.color.border-danger}", "$extensions": { "composa": { "aliasKey": "color.border.danger" } } },
      "bg-success": { "$type": "color", "$value": "{figma.composa.color.bg-success}", "$extensions": { "composa": { "aliasKey": "color.bg.success" } } },
      "text-success": { "$type": "color", "$value": "{figma.composa.color.text-success}", "$extensions": { "composa": { "aliasKey": "color.text.success" } } },
      "icon-success": { "$type": "color", "$value": "{figma.composa.color.icon-success}", "$extensions": { "composa": { "aliasKey": "color.icon.success" } } },
      "border-success": { "$type": "color", "$value": "{figma.composa.color.border-success}", "$extensions": { "composa": { "aliasKey": "color.border.success" } } },
      "bg-warning": { "$type": "color", "$value": "{figma.composa.color.bg-warning}", "$extensions": { "composa": { "aliasKey": "color.bg.warning" } } },
      "text-warning": { "$type": "color", "$value": "{figma.composa.color.text-warning}", "$extensions": { "composa": { "aliasKey": "color.text.warning" } } },
      "icon-warning": { "$type": "color", "$value": "{figma.composa.color.icon-warning}", "$extensions": { "composa": { "aliasKey": "color.icon.warning" } } },
      "border-warning": { "$type": "color", "$value": "{figma.composa.color.border-warning}", "$extensions": { "composa": { "aliasKey": "color.border.warning" } } },
