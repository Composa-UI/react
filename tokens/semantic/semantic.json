    "radius": {
      "none": { "$type": "dimension", "$value": "{figma.composa.radius.none}", "$extensions": { "composa": { "aliasKey": "radius.none" } } },
      "small": { "$type": "dimension", "$value": "{figma.composa.radius.small}", "$extensions": { "composa": { "aliasKey": "radius.small" } } },
      "medium": { "$type": "dimension", "$value": "{figma.composa.radius.medium}", "$extensions": { "composa": { "aliasKey": "radius.medium" } } },
