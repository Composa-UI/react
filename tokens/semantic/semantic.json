      "3": { "$type": "dimension", "$value": "{figma.composa.space.3}", "$extensions": { "composa": { "aliasKey": "space.3" } } },
      "4": { "$type": "dimension", "$value": "{figma.composa.space.4}", "$extensions": { "composa": { "aliasKey": "space.4" } } },
      "5": { "$type": "dimension", "$value": "{figma.composa.space.5}", "$extensions": { "composa": { "aliasKey": "space.5" } } },
      "6": { "$type": "dimension", "$value": "{figma.composa.space.6}", "$extensions": { "composa": { "aliasKey": "space.6" } } }
    },
    "height": {
      "input": { "$type": "dimension", "$value": "{figma.composa.height.input}", "$extensions": { "composa": { "aliasKey": "height.input" } } },
      "heading": { "$type": "dimension", "$value": "{figma.composa.height.heading}", "$extensions": { "composa": { "aliasKey": "height.heading" } } }
    },
    "font": {
      "family": { "$type": "fontFamily", "$value": "{figma.composa.font.family}", "$extensions": { "composa": { "aliasKey": "font.family" } } }
    },
    "body": {
      "small": {
        "size": { "$type": "dimension", "$value": "{figma.composa.body.small.size}", "$extensions": { "composa": { "aliasKey": "body.small.size" } } },
        "line": { "$type": "dimension", "$value": "{figma.composa.body.small.line}", "$extensions": { "composa": { "aliasKey": "body.small.lineHeight" } } },
        "weight": { "$type": "fontWeight", "$value": "{figma.composa.body.small.weight}", "$extensions": { "composa": { "aliasKey": "body.small.weight" } } },
        "strong-weight": { "$type": "fontWeight", "$value": "{figma.composa.body.small.strong-weight}", "$extensions": { "composa": { "aliasKey": "body.small.strongWeight" } } },
        "letter-spacing": { "$type": "dimension", "$value": "{figma.composa.body.small.letter-spacing}", "$extensions": { "composa": { "aliasKey": "body.small.letterSpacing" } } }
      },
      "medium": {
