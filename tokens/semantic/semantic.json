      "1": { "$type": "dimension", "$value": "{figma.composa.space.1}", "$extensions": { "composa": { "aliasKey": "space.1" } } },
      "2": { "$type": "dimension", "$value": "{figma.composa.space.2}", "$extensions": { "composa": { "aliasKey": "space.2" } } },
